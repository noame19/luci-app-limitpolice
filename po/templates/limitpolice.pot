msgid "Rule"
msgstr ""

#: files/usr/lib/lua/luci/model/cbi/limitpolice_edit.lua:57
msgid "Either an IPv4/CIDR or a colon-separated MAC."
msgstr ""

#: files/usr/lib/lua/luci/model/cbi/limitpolice_edit.lua:63
msgid ""
"<b>dst</b> caps packets <em>to</em> the device → pair with a WAN-side iface "
"(e.g. <code>wan</code>, <code>pppoe-wan</code>, <code>eth1</code>).<br/"
"><b>src</b> caps packets <em>from</em> the device → pair with a LAN-side "
"iface (e.g. <code>br-lan</code>, <code>eth0</code>).<br/>Wrong pairing = "
"rule matches zero packets = silently wasted slot."
msgstr ""

#: files/usr/lib/lua/luci/model/cbi/limitpolice_edit.lua:87
msgid ""
"When exceeded, this device's filter is dropped to the throttle rate "
"configured in the main section until the next 00:00 reset. Counted from "
"<code>tc -s filter show</code> bytes."
msgstr ""

