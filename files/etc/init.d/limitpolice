#!/bin/sh /etc/rc.common
# luci-app-limitpolice - per-device ingress bandwidth policing
# Compatible with Flow Offloading / fullcon NAT / BBR.
# Uses sch_ingress + act_police + cls_u32 (or cls_flower).
#
# Rule schema (UCI):
#   config rule
#       option enabled  '1'
#       option interface 'br-lan'             # WAN iface for dst, LAN iface for src
#       option target   '192.168.1.100/32'   # CIDR or single IP or MAC (xx:xx:xx:xx:xx:xx)
#       option target_type 'ip'              # ip | mac
#       option direction 'dst'               # dst (downlink) | src (uplink)
#       option rate '10'                     # numeric
#       option unit  'Mbps'                  # Kbps | Mbps | KB/s | MB/s
#       option comment 'iphone'              # free text
#
# Direction/iface pairing (validated by apply_rule, mismatched combos
# log a warning and are skipped):
#   dst (downlink)  → iface MUST be a WAN-side iface (where packets
#                     from the internet first hit ingress)
#   src (uplink)    → iface MUST be a LAN-side iface (where packets
#                     from the device first hit ingress)

START=90
STOP=10
USE_PROCD=1     # procd runs the script as a managed service so we can
                # register a UCI reload trigger below.

LOG_PREFIX="limitpolice"
PRIO_BASE=100   # filter priority base; our rules live in 100..199
PRIO_MAX=199
# stats filters live in a separate, high prio band so they never collide
# with user rules. They are added lazily by limitpolice-quota-check (every
# 5 min) for each active DHCP lease as a no-op counter (police rate 999gbit)
# — see that script for the lifecycle.
STATS_PRIO_BASE=9000
STATS_PRIO_MAX=9999
STATE_FILE="/var/run/limitpolice.filters"
QDISC_STATE_FILE="/var/run/limitpolice.qdiscs"
STATS_STATE_FILE="/var/run/limitpolice.stats"
# Mutual exclusion between init.d's tc add/del and quota-check's tc add/del.
# rtnetlink is a kernel-internal lock; concurrent tc users serialize on
# it, and `RTNETLINK answers: File exists` is the visible symptom on
# weak CPUs. Quota-check and stats-backup already flock this file;
# init.d does the same so reload+daemon can never race.
LOCK_FILE="/var/run/limitpolice/.lock"

# /etc/functions.sh is sourced by /etc/rc.common (which this script's
# `#!/bin/sh /etc/rc.common` shebang pulls in). Older revisions of
# this script had an explicit `. /etc/functions.sh` here, but modern
# OpenWrt / ImmortalWrt moved functions.sh to /lib/functions.sh and
# rc.common sources it for us. Re-source here would fail on every
# modern build (no /etc/functions.sh symlink).

log_msg() {
    local level="$1"; shift
    logger -t "$LOG_PREFIX" -p "daemon.$level" "$*"
}

# Classify an iface name into "wan" | "lan" | "unknown" by:
#   1. If it's the current IPv4 default route's interface → WAN.
#   2. Heuristic by name (handles common OpenWrt naming conventions).
# The result is used to validate that the user picked a sensible
# iface/direction combo in their rule (see apply_rule).
iface_role() {
    local iface="$1"
    local def
    def=$(ip -4 route show default 2>/dev/null | awk '{print $5; exit}')
    if [ -n "$def" ] && [ "$iface" = "$def" ]; then
        echo wan; return
    fi
    case "$iface" in
        br-lan|br-guest|br-*|lan|lan[0-9]|lan_*|wlan*|ath*|rai*)
            echo lan ;;
        wan|wan6|wan[0-9]|wan_*|wwan*|pppoe-wan*|usb*|wwan0)
            echo wan ;;
        *)
            echo unknown ;;
    esac
}

# load kernel modules required by tc police
load_modules() {
    local need_reload=0
    for m in sch_ingress act_police cls_u32 cls_flower; do
        if ! grep -q "^$m " /proc/modules 2>/dev/null; then
            if /sbin/modprobe "$m" 2>/dev/null; then
                log_msg info "loaded $m"
            else
                # cls_flower is optional; others are mandatory
                [ "$m" = "cls_flower" ] || log_msg warn "cannot load $m (built-in?)"
            fi
        fi
    done
}

# convert user-facing unit to kbit (integer)
unit_to_kbit() {
    local rate="$1" unit="$2"
    case "$unit" in
        Kbps|kbps|KBps)  echo $(( rate * 1 )) ;;
        Mbps|Mbps)        echo $(( rate * 1000 )) ;;
        KBps|KBps)        echo $(( rate * 8 )) ;;
        MBps|MBps)        echo $(( rate * 8000 )) ;;
        *)                echo $(( rate * 1000 )) ;;   # default: Mbps
    esac
}

# burst size heuristic (in kbit).  Keep ≥ 32k to absorb typical ACK bursts.
compute_burst() {
    local kbit="$1"
    local b=$(( kbit / 8 ))
    [ "$b" -lt 32 ] && b=32
    echo $(( b * 8 ))   # express in kbit as tc expects
}

# build one tc filter command line into $cmd; returns 0 on success
build_filter_cmd() {
    local cmd_var="$1" rule_name="$2" prio="$3" iface="$4"
    local target target_type direction rate unit comment enabled
    config_get_bool enabled "$rule_name" enabled 1
    [ "$enabled" = "1" ] || return 1
    config_get target      "$rule_name" target      ""
    config_get target_type "$rule_name" target_type "ip"
    config_get direction   "$rule_name" direction   "dst"
    config_get rate        "$rule_name" rate        ""
    config_get unit        "$rule_name" unit        "Mbps"
    [ -z "$target" ] && return 1
    [ -z "$rate" ]   && return 1

    local kbit=$(unit_to_kbit "$rate" "$unit")
    local burst=$(compute_burst "$kbit")
    local match=""
    local proto="ip"

    if [ "$target_type" = "mac" ]; then
        # u32 match on Ethernet header. Format match pattern derived from
        # eqosplus pattern: 6 bytes of MAC at offsets -2..-14 in the ethernet frame.
        local M0=$(echo "$target" | awk -F: '{printf "%s%s", $1, $2}')
        local M1=$(echo "$target" | awk -F: '{printf "%s%s", $3, $4}')
        local M2=$(echo "$target" | awk -F: '{printf "%s%s", $5, $6}')
        if [ "$direction" = "src" ]; then
            # src MAC: bytes 6..11 → offsets -2 (etype), -4..-9 (mac), etc
            match="match u16 0x0800 0xFFFF at -2 \
                   match u16 0x${M2} 0xFFFF at -4 \
                   match u32 0x${M0}${M1} 0xFFFFFFFF at -8"
        else
            # dst MAC: bytes 0..5 → offsets -14 (etype), -12..-7 (mac)
            match="match u16 0x0800 0xFFFF at -2 \
                   match u16 0x${M1}${M2} 0xFFFFFFFF at -12 \
                   match u16 0x${M0} 0xFFFF at -14"
        fi
    else
        # IP match
        if [ "$direction" = "src" ]; then
            match="match ip src $target"
        else
            match="match ip dst $target"
        fi
    fi

    local cmd="tc filter add dev $iface parent ffff: protocol $proto prio $prio u32 $match police rate ${kbit}kbit burst ${burst}k mtu 12k drop flowid :1"
    eval "$cmd_var=\$cmd"
    return 0
}

# ensure ingress qdisc on iface; record what we created so we don't disturb others
ensure_ingress_qdisc() {
    local iface="$1"
    if ! ip link show dev "$iface" >/dev/null 2>&1; then
        log_msg err "interface $iface not found"
        return 1
    fi
    if tc qdisc show dev "$iface" ingress 2>/dev/null | grep -q "ingress qdisc ffff:"; then
        return 0
    fi
    if tc qdisc add dev "$iface" handle ffff: ingress 2>/dev/null; then
        echo "$iface" >> "$QDISC_STATE_FILE"
        log_msg info "ingress qdisc added on $iface"
    else
        log_msg err "failed to add ingress qdisc on $iface"
        return 1
    fi
}

# remove all filters that we own on iface — both user-rule band (100..199)
# and stats band (9000..9999). quota-check allocates stats prios so it can
# rebuild them on next run; we just nuke the band here.
clear_filters_on_iface() {
    local iface="$1"
    tc -s filter show dev "$iface" parent ffff: 2>/dev/null | \
        grep -oE "pref [0-9]+" | awk '{print $2}' | \
        while read -r p; do
            { [ "$p" -ge "$PRIO_BASE"      ] && [ "$p" -le "$PRIO_MAX" ];      } || \
            { [ "$p" -ge "$STATS_PRIO_BASE" ] && [ "$p" -le "$STATS_PRIO_MAX" ]; } || continue
            tc filter del dev "$iface" parent ffff: prio "$p" 2>/dev/null
        done
}

clear_all_rules() {
    local iface
    for iface in $(uci show limitpolice 2>/dev/null | sed -n "s/^limitpolice\.\(@rule\[[0-9]*\]\.interface\)=\(.*\)/\2/p" | sort -u); do
        [ -n "$iface" ] && clear_filters_on_iface "$iface"
    done
    # also pick up interfaces from current state file
    [ -f "$STATE_FILE" ] && cut -d' ' -f1 "$STATE_FILE" 2>/dev/null | sort -u | while read -r iface; do
        [ -n "$iface" ] && clear_filters_on_iface "$iface"
    done
}

# Restore the per-device stats accumulator files from the on-flash tarball.
# Called from start_service() before the daemon comes up. Idempotent: no
# action when /etc/limitpolice/stats_backup.tar.gz is missing.
# Tradeoff: protects against active reboot (LuCI Save & Apply, upgrade,
# "reboot" from CLI). Does NOT protect against power loss — the most
# recent quota-check cycle's delta is gone if the box dies between
# backup_interval cycles. README documents this.
restore_stats_backup() {
    local archive=/etc/limitpolice/stats_backup.tar.gz
    [ -f "$archive" ] || return 0
    mkdir -p /tmp/limitpolice 2>/dev/null || return 1
    if tar xzf "$archive" -C /tmp/limitpolice 2>/dev/null; then
        log_msg info "restored stats backup from $archive"
    else
        log_msg warn "stats backup present but tar extract failed"
    fi
}

# Snapshot the per-device stats accumulators to flash. Called from
# stop_service() so a graceful shutdown or "Save & Apply" always leaves
# a fresh backup. Failures are non-fatal — old backup is kept.
backup_stats_now() {
    /usr/sbin/limitpolice-stats-backup 2>/dev/null
}

# Tell procd to watch /etc/config/limitpolice for changes. On any
# modification (LuCI Save & Apply, `uci set` from SSH, manual `vi`, …)
# procd will invoke reload_service() which re-syncs UCI → tc.
service_triggers() {
    procd_add_reload_trigger "limitpolice"
}

start_service() {
    load_modules
    : > "$STATE_FILE"
    : > "$QDISC_STATE_FILE"

    config_load limitpolice

    local main_enabled
    config_get_bool main_enabled main enabled 0

    # Restore stats accumulator files from the previous backup before
    # anything else touches /tmp/limitpolice/stats. Even if the user has
    # no rules today the daemon still needs the counters alive so quota
    # deltas resume from yesterday's baseline.
    restore_stats_backup

    # Walk user rules first so the existing tc filters are in place before
    # the daemon wakes up and starts reading tc -s filter show. If the
    # service is disabled in UCI we still need the daemon up so quota
    # stats continue to be collected (it's a pure reporting feature).
    if [ "$main_enabled" = "1" ]; then
        # Acquire exclusive flock for the tc-touching phase. Release
        # before procd_open_instance so the daemon (when its quota-check
        # wakes up) can take the same lock without deadlocking.
        exec 8>"$LOCK_FILE" 2>/dev/null
        flock -x -w 10 8 || {
            log_msg err "cannot acquire $LOCK_FILE — quota-check still running?"
            exec 8>&- 2>/dev/null
            return 1
        }
        local prio=$PRIO_BASE
        local iface_seen=""
        config_foreach apply_rule rule prio
        flock -u 8 2>/dev/null
        exec 8>&- 2>/dev/null
    fi

    # Pull the unique daemon process up. It runs `while true; sleep 10`,
    # schedules quota-check every stats_interval seconds, and watches the
    # date itself for daily / weekly / monthly bucket resets + the 00:00
    # quota-reset. procd respawn catches OOM / accidental kill.
    procd_open_instance
    procd_set_param command /usr/sbin/limitpoliced
    procd_set_param respawn
    procd_set_param stdout 0
    procd_set_param stderr 1
    procd_close_instance
}

apply_rule() {
    local rule_name="$1" var_prio="$2"
    local iface target enabled direction role
    config_get_bool enabled "$rule_name" enabled 1
    [ "$enabled" = "1" ] || return 0
    config_get iface "$rule_name" interface ""
    [ -z "$iface" ] && {
        log_msg warn "rule $rule_name has no interface, skipping"
        return 0
    }
    config_get direction "$rule_name" direction "dst"

    # Validate iface/direction pairing. An ingress qdisc on iface X sees
    # packets ENTERING X — so for downlink (dst) we want the WAN iface
    # (where packets from the internet first arrive); for uplink (src)
    # we want the LAN bridge. The wrong combo would match zero packets
    # and silently waste the rule's prio slot.
    role=$(iface_role "$iface")
    case "${direction}-${role}" in
        dst-wan|src-lan) : ;;                       # canonical pair
        dst-unknown|src-unknown) ;;                 # accept but stay quiet
        *)
            log_msg warn "rule $rule_name: iface=$iface (role=$role) with direction=$direction — likely ineffective. dst wants WAN, src wants LAN. Skipping."
            return 0
            ;;
    esac

    ensure_ingress_qdisc "$iface" || return 0

    # allocate a fresh prio for this rule
    eval local current_prio=\$$var_prio
    local prio=$current_prio
    eval $var_prio=$(( current_prio + 1 ))
    [ "$prio" -gt "$PRIO_MAX" ] && {
        log_msg err "too many rules (>$(( PRIO_MAX - PRIO_BASE )))"
        return 0
    }

    local cmd
    if build_filter_cmd cmd "$rule_name" "$prio" "$iface"; then
        if eval "$cmd" 2>/dev/null; then
            echo "$iface $prio $rule_name" >> "$STATE_FILE"
            log_msg info "applied: $cmd"
        else
            log_msg err "filter failed: $cmd"
        fi
    fi
}

stop_service() {
    # Acquire flock so we never race quota-check's stats filter rebuild.
    exec 8>"$LOCK_FILE" 2>/dev/null
    flock -x -w 10 8 || {
        log_msg err "cannot acquire $LOCK_FILE — quota-check still running?"
        exec 8>&- 2>/dev/null
        return 1
    }
    # Snapshot stats before wiping — this is the active-reboot safety net.
    backup_stats_now
    clear_all_rules
    # remove ingress qdiscs only if we added them
    [ -f "$QDISC_STATE_FILE" ] && while read -r iface; do
        [ -z "$iface" ] && continue
        tc qdisc del dev "$iface" ingress 2>/dev/null && \
            log_msg info "removed ingress qdisc on $iface"
    done < "$QDISC_STATE_FILE"
    rm -f "$STATE_FILE" "$QDISC_STATE_FILE" "$STATS_STATE_FILE"
    # also clear the daily/weekly/monthly stats files — they're in /tmp so
    # reboot already wipes them, but a clean stop should leave nothing.
    rm -rf /tmp/limitpolice/stats
    flock -u 8 2>/dev/null
    exec 8>&- 2>/dev/null
}

reload_service() {
    stop_service
    start_service
}

status_service() {
    echo "luci-app-limitpolice status"
    echo "----------------------------"
    if [ -f "$STATE_FILE" ]; then
        cat "$STATE_FILE"
    else
        echo "(no active rules)"
    fi
    echo "--- ingress qdiscs ---"
    for i in $(ls /sys/class/net 2>/dev/null); do
        tc -s qdisc show dev "$i" ingress 2>/dev/null | grep -q . && echo "$i"
    done
}
