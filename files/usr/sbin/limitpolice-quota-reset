#!/bin/sh
# /usr/sbin/limitpolice-quota-reset
#
# Cron entry: 0 0 * * *. Daily reset: clear per-IP accumulators and
# restart the init script so any throttled (1 kbit) filters are rebuilt
# at their normal UCI-declared rate. This is the only mechanism that
# lifts a punitive block — automatic, no SSH needed.

SNAP=/var/run/limitpolice/quota
rm -f "$SNAP"
/etc/init.d/limitpolice restart
logger -t limitpolice-quota "daily reset: counters cleared, service restarted"